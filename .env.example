# FaceBase Environment Variables
# Copy this to .env.local and fill in your values

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Database (Neon Postgres)
